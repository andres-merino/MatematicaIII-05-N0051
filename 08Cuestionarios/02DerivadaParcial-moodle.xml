<question type="multichoice">
  <name format="html">
    <text><![CDATA[DG-Dir-01]]></text>
  </name>
  <questiontext format="html">
    <text><![CDATA[<p>La derivada direccional \(f&rsquo;({x};{u})\) representa: </p>]]></text>
  </questiontext>
