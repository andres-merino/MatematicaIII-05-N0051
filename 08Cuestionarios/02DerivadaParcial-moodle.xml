<question type="multichoice">
  <name format="html">
    <text><![CDATA[DP-Concepto-04]]></text>
  </name>
  <questiontext format="html">
    <text><![CDATA[<p>El teorema de Schwarz establece que, bajo condiciones de regularidad: </p>]]></text>
