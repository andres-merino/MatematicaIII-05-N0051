<question type="multichoice">
  <name format="html">
    <text><![CDATA[GC-VectoresTriedro-01]]></text>
  </name>
  <questiontext format="html">
    <text><![CDATA[<p>Dada \( \alpha \colon I \rightarrow \mathbb {R}^3\) con \(\alpha &rsquo;(t)\neq 0\), ¿cuál es la definición del vector unitario tangente \(T_\alpha (t)\)? </p>]]></text>
  </questiontext>
  <defaultgrade>1.0</defaultgrade>
  <generalfeedback format="html"><text/></generalfeedback>
  <penalty>0.10</penalty>
  <hidden>0</hidden>
  <single>true</single>
  <shuffleanswers>1</shuffleanswers>
  <answernumbering>abc</answernumbering>
  <answer fraction="100" format="html">
    <text><![CDATA[<p>\(T_\alpha (t)=\dfrac {\alpha &rsquo;(t)}{\|\alpha &rsquo;(t)\|}\)</p>]]></text>
  </answer>
  <answer fraction="0" format="html">
    <text><![CDATA[<p>\(T_\alpha (t)=\dfrac {T_\alpha &rsquo;(t)}{\|T_\alpha &rsquo;(t)\|}\)</p>]]></text>
  </answer>
  <answer fraction="0" format="html">
    <text><![CDATA[<p>\(T_\alpha (t)=T_\alpha (t)\times N_\alpha (t)\)</p>]]></text>
  </answer>
  <answer fraction="0" format="html">
    <text><![CDATA[<p>\(T_\alpha (t)=\alpha &rsquo;(t)\cdot \alpha &rsquo;&rsquo;(t)\)</p>]]></text>
  </answer>
</question>
