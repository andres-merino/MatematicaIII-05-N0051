<question type="multichoice">
  <name format="html">
    <text><![CDATA[FV-CadenaRegla-01]]></text>
  </name>
  <questiontext format="html">
    <text><![CDATA[<p>Si \( u\colon I \rightarrow \mathbb {R}\) es derivable en \(a\) y \( \alpha \colon J \rightarrow \mathbb {R}^m\) es derivable en \(u(a)\), la regla de la cadena para \(\alpha \circ u\) establece que: </p>]]></text>
  </questiontext>
  <defaultgrade>1.0</defaultgrade>
  <generalfeedback format="html"><text/></generalfeedback>
  <penalty>0.10</penalty>
  <hidden>0</hidden>
  <single>true</single>
  <shuffleanswers>1</shuffleanswers>
  <answernumbering>abc</answernumbering>
  <answer fraction="100" format="html">
    <text><![CDATA[<p>\((\alpha \circ u)&rsquo;(a)=u&rsquo;(a)&#8239;\alpha &rsquo;(u(a))\)</p>]]></text>
  </answer>
  <answer fraction="0" format="html">
    <text><![CDATA[<p>\((\alpha \circ u)&rsquo;(a)=\alpha &rsquo;(a)&#8239;u&rsquo;(u(a))\)</p>]]></text>
  </answer>
  <answer fraction="0" format="html">
    <text><![CDATA[<p>\((\alpha \circ u)&rsquo;(a)=\alpha &rsquo;(u(a))+u&rsquo;(a)\)</p>]]></text>
  </answer>
  <answer fraction="0" format="html">
    <text><![CDATA[<p>\((\alpha \circ u)&rsquo;(a)=u&rsquo;(a)+\alpha &rsquo;(a)\)</p>]]></text>
  </answer>
</question>
 
