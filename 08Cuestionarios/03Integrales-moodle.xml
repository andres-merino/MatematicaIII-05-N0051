<question type="multichoice">
  <name format="html">
    <text><![CDATA[CC-Def-01]]></text>
  </name>
  <questiontext format="html">
    <text><![CDATA[<p>Un campo vectorial \(\vec {F}\) es conservativo cuando: </p>]]></text>
  </questiontext>
  <defaultgrade>1.0</defaultgrade>
  <generalfeedback format="html"><text/></generalfeedback>
  <penalty>0.10</penalty>
  <hidden>0</hidden>
  <single>true</single>
  <shuffleanswers>1</shuffleanswers>
  <answernumbering>abc</answernumbering>
  <answer fraction="100" format="html">
    <text><![CDATA[<p>Proviene del gradiente de algún campo escalar, es decir, \(\vec {F} = \nabla f\).</p>]]></text>
  </answer>
  <answer fraction="0" format="html">
    <text><![CDATA[<p>Su divergencia es nula.</p>]]></text>
  </answer>
  <answer fraction="0" format="html">
    <text><![CDATA[<p>Es perpendicular a sus curvas de nivel.</p>]]></text>
  </answer>
  <answer fraction="0" format="html">
    <text><![CDATA[<p>Su jacobiano es invertible.</p>]]></text>
  </answer>
</question>
<question type="multichoice">
  <name format="html">
    <text><![CDATA[CC-Indep-01]]></text>
  </name>
  <questiontext format="html">
    <text><![CDATA[<p>En un campo vectorial conservativo, la integral de línea \(\displaystyle \int _C \vec {F}\cdot d\vec {r}\): </p>]]></text>
  </questiontext>
  <defaultgrade>1.0</defaultgrade>
  <generalfeedback format="html"><text/></generalfeedback>
  <penalty>0.10</penalty>
  <hidden>0</hidden>
  <single>true</single>
  <shuffleanswers>1</shuffleanswers>
  <answernumbering>abc</answernumbering>
  <answer fraction="100" format="html">
    <text><![CDATA[<p>No depende de la trayectoria, solo de los puntos inicial y final.</p>]]></text>
  </answer>
  <answer fraction="0" format="html">
    <text><![CDATA[<p>Depende de la longitud de la curva \(C\).</p>]]></text>
  </answer>
  <answer fraction="0" format="html">
    <text><![CDATA[<p>Es siempre positiva.</p>]]></text>
  </answer>
  <answer fraction="0" format="html">
    <text><![CDATA[<p>Cambia con cada parametrización de \(C\).</p>]]></text>
  </answer>
</question>
