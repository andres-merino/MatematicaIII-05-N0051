  </answer>
  <answer fraction="0" format="html">
    <text><![CDATA[<p>\(\displaystyle \iint _R f&#8239;dA = \iint _{R_1} f&#8239;dA \cdot \iint _{R_2} f&#8239;dA\)</p>]]></text>
  </answer>
  <answer fraction="0" format="html">
    <text><![CDATA[<p>\(\displaystyle \iint _R f&#8239;dA = \iint _{R_1} f&#8239;dA - \iint _{R_2} f&#8239;dA\)</p>]]></text>
  </answer>
  <answer fraction="0" format="html">
    <text><![CDATA[<p>\(\displaystyle \iint _R f&#8239;dA = \max \left (\iint _{R_1} f&#8239;dA,\ \iint _{R_2} f&#8239;dA\right )\)</p>]]></text>
  </answer>
</question>
